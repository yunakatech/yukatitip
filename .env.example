# ============================================================================
# Yukatitip Environment Variables Example
# Copy this file to .env for local development.
# Never commit .env or any file containing real credentials.
# Production secrets must be configured in Cloudflare Pages / Workers settings.
# ============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------

APP_ENV=<development|preview|production>
APP_NAME=<Yukatitip>
APP_URL=<http://localhost:5173>
PUBLIC_APP_NAME=<Yukatitip>
PUBLIC_APP_URL=<http://localhost:5173>
PUBLIC_API_BASE_URL=</api/v1>
LOG_LEVEL=<debug|info|warn|error>

# Timezone is used only for display and business-date calculations.
# Store database timestamps in UTC.
APP_TIMEZONE=<Asia/Makassar>

# ----------------------------------------------------------------------------
# Supabase — Public
# Safe to expose to the browser only when RLS is configured correctly.
# ----------------------------------------------------------------------------

PUBLIC_SUPABASE_URL=<https://your-project-ref.supabase.co>
PUBLIC_SUPABASE_PUBLISHABLE_KEY=<sb_publishable_xxxxxxxxxxxxxxxxx>

# ----------------------------------------------------------------------------
# Supabase — Server Only
# Never prefix server secrets with PUBLIC_.
# Never expose this value to the browser.
# ----------------------------------------------------------------------------

SUPABASE_SERVICE_ROLE_KEY=<sb_secret_xxxxxxxxxxxxxxxxx>

# ----------------------------------------------------------------------------
# Cloudflare Turnstile
# Site key is public. Secret key is server-only.
# ----------------------------------------------------------------------------

PUBLIC_TURNSTILE_SITE_KEY=<0x4AAAAAAAAAAAAAAAAAAAAA>
TURNSTILE_SECRET_KEY=<0x4AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA>

# ----------------------------------------------------------------------------
# Cloudflare R2
# For local development through the S3-compatible API.
# In Cloudflare production, prefer R2 bucket bindings configured in wrangler.
# ----------------------------------------------------------------------------

CLOUDFLARE_ACCOUNT_ID=<your-cloudflare-account-id>
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_S3_ENDPOINT=<https://your-account-id.r2.cloudflarestorage.com>
R2_PRIVATE_BUCKET_NAME=<yukatitip-private>
R2_PUBLIC_BUCKET_NAME=<yukatitip-public>

# Binding names expected by the application when deployed to Cloudflare.
R2_PRIVATE_BUCKET_BINDING=<YUKATITIP_PRIVATE_BUCKET>
R2_PUBLIC_BUCKET_BINDING=<YUKATITIP_PUBLIC_BUCKET>

# Optional public asset domain for production.
PUBLIC_ASSET_BASE_URL=<https://assets.example.com>

# ----------------------------------------------------------------------------
# Cloudflare KV
# KV is only for public configuration and cache, never transactional data.
# Configure the actual namespace binding in wrangler.
# ----------------------------------------------------------------------------

KV_CONFIG_BINDING=<YUKATITIP_CONFIG_KV>

# ----------------------------------------------------------------------------
# Cloudflare Rate Limiting
# Workers can use LOGIN_RATE_LIMITER. Cloudflare Pages can use KV with the
# existing YUKATITIP_CONFIG_KV binding.
# ----------------------------------------------------------------------------

LOGIN_RATE_LIMIT_STRATEGY=<binding|kv|waf>

# ----------------------------------------------------------------------------
# Security
# Generate unique random values for each environment.
# ----------------------------------------------------------------------------

CSRF_SECRET=<generate-a-long-random-secret>
IDEMPOTENCY_SECRET=<generate-a-long-random-secret>
SESSION_COOKIE_NAME=<yukatitip_session>
COOKIE_DOMAIN=<localhost-or-your-domain>
COOKIE_SECURE=<false|true>
COOKIE_SAME_SITE=<lax|strict>

# Optional trusted origins, comma-separated.
TRUSTED_ORIGINS=<http://localhost:5173,https://example.com>

# ----------------------------------------------------------------------------
# Upload Rules
# Values are placeholders and should match server-side validation.
# ----------------------------------------------------------------------------

MAX_UPLOAD_SIZE_BYTES=<5242880>
ALLOWED_IMAGE_MIME_TYPES=<image/jpeg,image/png,image/webp>
ALLOWED_DOCUMENT_MIME_TYPES=<application/pdf>
R2_UPLOAD_URL_TTL_SECONDS=<600>
R2_DOWNLOAD_URL_TTL_SECONDS=<300>

# ----------------------------------------------------------------------------
# Public API Protection
# ----------------------------------------------------------------------------

TRACKING_RATE_LIMIT_REQUESTS=<10>
TRACKING_RATE_LIMIT_WINDOW_SECONDS=<60>
LOGIN_RATE_LIMIT_REQUESTS=<5>
LOGIN_RATE_LIMIT_WINDOW_SECONDS=<60>
ORDER_CREATE_RATE_LIMIT_REQUESTS=<5>
ORDER_CREATE_RATE_LIMIT_WINDOW_SECONDS=<3600>

# ----------------------------------------------------------------------------
# Business Configuration
# Prefer database settings for values that can change per branch or over time.
# These are fallback values only.
# ----------------------------------------------------------------------------

DEFAULT_CURRENCY=<IDR>
DEFAULT_LOCALE=<id-ID>
DEFAULT_PAGE_SIZE=<20>
MAX_PAGE_SIZE=<100>
TRACKING_PHONE_LAST_DIGITS=<4>

# ----------------------------------------------------------------------------
# Optional Development Settings
# Do not enable in production.
# ----------------------------------------------------------------------------

ENABLE_DEV_SEED=<false|true>
ENABLE_DEBUG_ROUTES=<false|true>
DISABLE_TURNSTILE_IN_LOCAL=<false|true>
MOCK_R2_UPLOADS=<false|true>
